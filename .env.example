# Copy this file to .env and fill in local values.
# Never commit real tokens, keys, or chat IDs.

DATABASE_URL=sqlite:///./daily_digest.db

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Optional. Used for higher Semantic Scholar API limits when configured.
SEMANTIC_SCHOLAR_API_KEY=

# Optional comma-separated feed URLs. Defaults in code include OpenAI,
# Anthropic, Google AI, Hugging Face, MIT Technology Review, and VentureBeat AI.
RSS_FEEDS=

DIGEST_MODE=topics
MAX_DIGEST_ITEMS=5
TOPIC_TIMEZONE=Asia/Phnom_Penh
TOPIC_SEND_START_HOUR=8
TOPIC_SEND_END_HOUR=22
TOPIC_DUE_WINDOW_MINUTES=75
HTTP_TIMEOUT_SECONDS=20
