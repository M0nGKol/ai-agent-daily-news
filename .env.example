# Copy this file to .env and fill in local values.
# Never commit real tokens, keys, or chat IDs.

DATABASE_URL=sqlite:///./daily_digest.db

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMAND_ALLOWED_IDS=
TELEGRAM_DIGEST_COMMAND=/digest
TELEGRAM_COMMAND_POLL_TIMEOUT_SECONDS=25

LLM_PROVIDER=
LLM_API_KEY=
LLM_MODEL=
LLM_BASE_URL=

# Optional. Used for higher Semantic Scholar API limits when configured.
SEMANTIC_SCHOLAR_API_KEY=

# Optional comma-separated feed URLs. Defaults in code include OpenAI,
# Anthropic, Google AI, Hugging Face, MIT Technology Review, and VentureBeat AI.
RSS_FEEDS=

DIGEST_MODE=topics
MAX_DIGEST_ITEMS=5
DIGEST_REPEAT_LOOKBACK_DAYS=14
MAX_ITEMS_PER_SOURCE_DOMAIN=1
GDELT_ENABLED=true
GDELT_QUERY='("artificial intelligence" OR "generative AI" OR "large language model" OR "AI agent" OR "machine learning")'
GDELT_TIMESPAN=3d
GDELT_MAX_RECORDS=50
TOPIC_TIMEZONE=Asia/Phnom_Penh
TOPIC_SEND_START_HOUR=8
TOPIC_SEND_END_HOUR=22
TOPIC_DUE_WINDOW_MINUTES=75
HTTP_TIMEOUT_SECONDS=20
